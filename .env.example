# ── Generate mode LLM ──
GEN_PROVIDER=openai              # "anthropic" or "openai"
GEN_MODEL=gpt-5.2
GEN_BASE_URL=
GEN_API_KEY=
GEN_TEMPERATURE=0.3
GEN_MAX_TOKENS=4096

# ── Evaluate mode LLM ──
EVAL_PROVIDER=openai             # "anthropic" or "openai"
EVAL_MODEL=gpt-5.2
EVAL_BASE_URL=
EVAL_API_KEY=
EVAL_TEMPERATURE=0.3
EVAL_MAX_TOKENS=20480

# ── Raw LLM patch generation (toolkits/llm_patch_generator.py) ──
RAW_GEN_PROVIDER=openai          # "openai" or "anthropic"
RAW_GEN_MODEL=
RAW_GEN_BASE_URL=
RAW_GEN_API_KEY=
RAW_GEN_TEMPERATURE=0.3
RAW_GEN_MAX_TOKENS=8192

# Platform tokens (optional)
GITHUB_TOKEN=
GITEE_TOKEN=
